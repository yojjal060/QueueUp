{
  "name": "queueup-server",
  "version": "1.0.0",
  "description": "QueueUp — Real-time matchmaking platform backend",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc --noEmit",
    "start": "tsx server.ts",
    "postinstall": "prisma generate",
    "seed": "tsx seed.ts",
    "smoke:realtime": "tsx scripts/realtimeSmoke.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "keywords": [],
  "author": "Yojjal",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0"
  }
